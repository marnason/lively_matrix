{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Package matrix-wallpaper-v2.zip",
			"type": "shell",
			"command": "Compress-Archive -Path source\\* -DestinationPath release\\matrix-wallpaper-v2.zip -Force",
